# Copy this file to .env and fill in your real keys for local development.
# On Streamlit Cloud, set these same keys under App Settings -> Secrets instead
# (in TOML format -- see README.md for the exact block to paste).

# Anthropic API key -- https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Which Claude model to use for extraction + verification reasoning
CLAUDE_MODEL=claude-sonnet-4-6

# Google Custom Search -- https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Create a Programmable Search Engine at https://programmablesearchengine.google.com/
# set it to "Search the entire web", then copy its Search engine ID here:
GOOGLE_CSE_ID=xxxxxxxxxxxxxxxxx

# Optional pipeline tuning (sane defaults already set in src/config.py)
MAX_CLAIMS_PER_DOC=15
SEARCH_RESULTS_PER_CLAIM=5
MAX_PDF_PAGES=30
